{
  "name": "@sleeper-caffeine/mcp",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Read-only Sleeper fantasy football MCP server.",
  "license": "MIT",
  "bin": {
    "sleeper-mcp": "dist/src/index.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/public.d.ts",
      "import": "./dist/src/public.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test scripts",
    "test": "vitest run --exclude test/live/**",
    "test:live": "RUN_LIVE_TESTS=1 vitest run test/live",
    "cache:refresh": "tsx scripts/refresh-player-cache.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sleeper-caffeine/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsx": "4.23.1"
  }
}
